{
  "name": "gym-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "node apps/web/server.js",
    "dev:api": "node apps/api/server.js",
    "dev:auth": "node services/auth/server.js",
    "build": "node -e \"console.log('No build step yet; the MVP runs directly on Node')\"",
    "lint": "node -e \"console.log('No lint step yet')\"",
    "test": "node -e \"console.log('No test suite yet')\""
  }
}